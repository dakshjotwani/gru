<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  com.gru.server — LaunchAgent that supervises the local gru server.

  Install via scripts/install-autodeploy.sh (copies to ~/Library/LaunchAgents,
  substitutes $HOME, and bootstraps into launchd).

  The server's binary lives at <REPO>/gru and is rebuilt in place by
  autodeploy.sh. `KeepAlive` keeps it running; `kickstart -k` during autodeploy
  stops the old process so launchd relaunches against the fresh binary.
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.gru.server</string>

  <key>ProgramArguments</key>
  <array>
    <string>__HOME__/workspace/gru/gru</string>
    <string>server</string>
  </array>

  <key>WorkingDirectory</key>
  <string>__HOME__/workspace/gru</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>HOME</key>
    <string>__HOME__</string>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
  </dict>

  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>

  <!-- Back off on crash loops so a broken build doesn't hammer launchd. -->
  <key>ThrottleInterval</key>
  <integer>10</integer>

  <key>StandardOutPath</key>
  <string>__HOME__/.gru/logs/server.launchd.log</string>
  <key>StandardErrorPath</key>
  <string>__HOME__/.gru/logs/server.launchd.log</string>
</dict>
</plist>
