#!/bin/sh
# _deploy — common dispatcher for git hooks (post-commit, post-merge, etc).
#
# Bails fast on no-op events (not on main, HEAD unchanged from deployed.sha, in
# a linked worktree). Otherwise spawns scripts/redeploy.sh in the background so
# the git command itself returns immediately.
set -eu

REPO="$(git rev-parse --show-toplevel)"
BRANCH="${GRU_AUTODEPLOY_BRANCH:-main}"
STATE_DIR="${GRU_STATE_DIR:-$HOME/.gru}"
LOG_DIR="${GRU_LOG_DIR:-$HOME/Library/Logs/gru}"
DEPLOYED_FILE="$STATE_DIR/deployed.sha"
LOG="$LOG_DIR/autodeploy.log"

# Skip hooks fired in linked worktrees (.git is a file pointing into the main
# repo's worktrees/ dir). Only the canonical main worktree triggers redeploys.
GIT_DIR="$(git rev-parse --git-dir)"
GIT_COMMON_DIR="$(git rev-parse --git-common-dir)"
[ "$GIT_DIR" = "$GIT_COMMON_DIR" ] || exit 0

# Skip when not on the tracking branch.
[ "$(git rev-parse --abbrev-ref HEAD)" = "$BRANCH" ] || exit 0

# Skip when HEAD hasn't moved past the last deployed sha.
deployed=""
[ -f "$DEPLOYED_FILE" ] && deployed="$(cat "$DEPLOYED_FILE" 2>/dev/null || true)"
current="$(git rev-parse HEAD)"
[ "$deployed" != "$current" ] || exit 0

mkdir -p "$LOG_DIR"

# Detach so `git commit` / `git pull` / etc don't block on the rebuild.
nohup "$REPO/scripts/redeploy.sh" >> "$LOG" 2>&1 < /dev/null &
disown 2>/dev/null || true

echo "[gru-deploy] background rebuild kicked off ($(echo "$current" | cut -c1-8); log: $LOG)" >&2
